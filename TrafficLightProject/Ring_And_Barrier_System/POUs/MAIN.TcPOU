// Detect a falling edge of the traffic phase being busy
//IF fb_Detect_Phase_Complete.Q THEN
	//b_Trigger := FALSE;
//END_IF

// Testing flashing stop
fb_Major_Street_Left_Turn_Phase_1.Flashing_Stop(b_Stop_Traffic := b_Trigger);]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>